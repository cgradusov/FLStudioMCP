# --- Runtime artifacts produced by the bridge ----------------------------
# JSON request/state files that the piano-roll pyscript exchanges with the
# FL side — they're regenerated on every tool call and are user-specific.
fLMCP_request.json
fLMCP_state.json

# --- Audio capture scratch -----------------------------------------------
# Mic recordings go to the system temp dir by default, but keep the repo
# clean if anything lands here.
*.wav
*.flac
*.mp3
*.ogg
!tests/**/fixtures/*.wav
